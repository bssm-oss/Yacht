{
  "name": "@dice/frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Electron + React + Three.js frontend for BSSM Dice",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && tsc -p electron/tsconfig.json && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src electron",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.170.0",
    "zustand": "^5.0.3",
    "socket.io-client": "^4.8.1",
    "@dice/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.9",
    "eslint": "^9.23.0"
  }
}
