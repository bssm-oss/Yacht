{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../..",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../../packages/shared/src/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "electron/**/*", "../../packages/shared/src/types/**/*", "../../packages/shared/src/scoring.ts", "../../packages/shared/src/index.ts"],
  "exclude": ["node_modules", "dist", "dist-electron", "**/*.test.ts"]
}
