# Google OAuth 설정
# Google Cloud Console → APIs & Services → Credentials 에서 생성
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=https://your-backend.com/auth/google/callback

# JWT 시크릿 (랜덤 문자열로 교체하세요)
JWT_SECRET=change-me-to-a-random-secret

# 프론트엔드 URL (OAuth 콜백 후 리다이렉트 대상)
FRONTEND_URL=https://your-frontend.com

# 서버 포트
PORT=3001

# PostgreSQL 데이터베이스 연결 URL
# CloudType 외부 접속: svc.sel3.cloudtype.app:30482 → postgresql:5432
DATABASE_URL=postgresql://user:password@svc.sel3.cloudtype.app:30482/yacht
